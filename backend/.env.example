# Backend Environment Variables
# Copy this file to .env and fill in your values

# Path to Firebase service account JSON (optional — app works without it but Firestore persistence will be disabled)
FIREBASE_SERVICE_ACCOUNT_PATH=

# Server port (default: 3000)
PORT=3000

# ── Email notifications (optional) ────────────────────────────────────────────
# Supports Gmail (use App Password), SendGrid, Mailgun, or any SMTP provider.
# Leave EMAIL_HOST blank to disable email notifications entirely.
#
#   Gmail:    EMAIL_HOST=smtp.gmail.com   EMAIL_PORT=587
#   SendGrid: EMAIL_HOST=smtp.sendgrid.net EMAIL_PORT=587 EMAIL_USER=apikey EMAIL_PASS=<API_KEY>

EMAIL_HOST=
EMAIL_PORT=587
EMAIL_USER=
EMAIL_PASS=
EMAIL_FROM="CivicSim <noreply@civicsim.io>"
